{
  "name": "@postbote/adapter-resend",
  "version": "0.0.0",
  "description": "Postbote-Adapter für Resend (natives SDK)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "resend": "^4"
  },
  "peerDependencies": {
    "@postbote/core": "workspace:^"
  },
  "devDependencies": {
    "@postbote/adapter-contract": "workspace:^",
    "@postbote/core": "workspace:^",
    "msw": "^2",
    "vitest": "^3"
  }
}
