{
  "name": "@postbote/testing",
  "version": "0.0.0",
  "description": "Consumer-Test-Kit: Test-Adapter, Inbox-Assertions, Vitest/Jest-Matcher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iduuck/postbote.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/iduuck/postbote#readme",
  "bugs": "https://github.com/iduuck/postbote/issues",
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./matchers": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@postbote/core": "workspace:^",
    "vitest": "^3"
  },
  "devDependencies": {
    "@postbote/core": "workspace:^",
    "vitest": "^3"
  }
}
