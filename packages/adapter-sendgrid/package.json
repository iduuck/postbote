  },
  "devDependencies": {
    "@postbote/adapter-contract": "workspace:^",
    "@postbote/core": "workspace:^",
    "msw": "^2",
    "vitest": "^3"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6"
  }
