{
  "name": "@postbote/adapter-sendgrid",
  "version": "1.0.0",
  "description": "Postbote adapter for SendGrid using the native SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iduuck/postbote.git",
    "directory": "packages/adapter-sendgrid"
  },
  "homepage": "https://github.com/iduuck/postbote#readme",
  "bugs": "https://github.com/iduuck/postbote/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
