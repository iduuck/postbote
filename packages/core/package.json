{
  "name": "@postbote/core",
  "version": "0.0.0",
  "description": "Provider-agnostisches E-Mail-SDK — Typen, Fehler, Middleware-Pipeline",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
