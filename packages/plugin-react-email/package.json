{
  "name": "@postbote/plugin-react-email",
  "version": "0.0.0",
  "description": "Render React components to html/text via react-email before sending",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@postbote/core": "workspace:^",
    "@react-email/render": "^1",
    "react": ">=18"
  },
  "devDependencies": {
    "@postbote/core": "workspace:^",
    "@postbote/testing": "workspace:^",
    "@react-email/render": "^1",
    "@types/react": "^19",
    "react": "^19",
    "react-dom": "^19",
    "vitest": "^3"
  }
}
