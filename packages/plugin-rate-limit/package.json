{
  "name": "@postbote/plugin-rate-limit",
  "version": "1.0.0",
  "description": "Client-side rate limiting middleware for Postbote",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@postbote/core": "workspace:^"
  },
  "devDependencies": {
    "@postbote/core": "workspace:^",
    "@postbote/testing": "workspace:^",
    "vitest": "^3"
  }
}
